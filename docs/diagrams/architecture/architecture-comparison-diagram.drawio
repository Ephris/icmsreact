        <mxCell id="conclusion-title" value="Why Monolithic MVC is Best for ICMS" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;fontColor=#1b5e20;" vertex="1" parent="1">
