        </mxCell>
        
        <mxCell id="reason1" value="1. Project Scale: ICMS is a departmental system with predictable, moderate user load" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="490" width="450" height="20" as="geometry" />
        </mxCell>
        <mxCell id="reason2" value="2. Development Team: Small to medium team can efficiently manage single codebase" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="510" width="450" height="20" as="geometry" />
        </mxCell>
        <mxCell id="reason3" value="3. Real-time Features: Laravel Events + Pusher provides native real-time support" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="530" width="450" height="20" as="geometry" />
        </mxCell>
        <mxCell id="reason4" value="4. Maintenance: Single codebase simplifies long-term maintenance and updates" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="550" y="490" width="450" height="20" as="geometry" />
        </mxCell>
        <mxCell id="reason5" value="5. Security: Server-side routing with Inertia.js provides inherent security benefits" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="550" y="510" width="450" height="20" as="geometry" />
        </mxCell>
        <mxCell id="reason6" value="6. Cost-Effective: Lower infrastructure and operational costs than distributed systems" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="550" y="530" width="450" height="20" as="geometry" />
